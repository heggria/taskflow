{
  "name": "codex-taskflow",
  "version": "0.1.2",
  "description": "Run taskflow on OpenAI Codex: a Codex subagent runner plus an MCP server (and a plug-and-play Codex plugin) that exposes the taskflow_* tools to Codex users.",
  "keywords": [
    "codex",
    "codex-cli",
    "mcp",
    "taskflow",
    "orchestration",
    "subagents",
    "workflow"
  ],
  "license": "MIT",
  "author": "heggria <bshengtao@gmail.com>",
  "homepage": "https://github.com/heggria/taskflow#readme",
  "bugs": {
    "url": "https://github.com/heggria/taskflow/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/heggria/taskflow.git",
    "directory": "packages/codex-taskflow"
  },
  "type": "module",
  "engines": {
    "node": ">=22.19.0"
  },
  "main": "./dist/codex-runner.js",
  "types": "./dist/codex-runner.d.ts",
  "bin": {
    "codex-taskflow-mcp": "./dist/mcp/bin.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "prepublishOnly": "npm run build"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "taskflow-core": "0.1.2"
  }
}
