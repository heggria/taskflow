    "pi-package",
    "pi",
    "pi-coding-agent",
    "pi-extension",
    "workflow",
    "orchestration",
    "subagents",
    "agents",
    "taskflow",
    "ai",
    "automation"
  ],
  "license": "MIT",
  "author": "heggria <bshengtao@gmail.com>",
  "homepage": "https://github.com/heggria/pi-taskflow#readme",
  "bugs": {
    "url": "https://github.com/heggria/pi-taskflow/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/heggria/pi-taskflow.git",
    "directory": "packages/pi-taskflow"
  },
  "type": "module",
  "files": ["src", "skills"],
  "publishConfig": {
    "access": "public"
  },
  "pi": {
    "extensions": ["./src/index.ts"],
