{
  "name": "opencode-taskflow",
  "version": "0.1.5",
  "description": "Run taskflow on OpenCode: an OpenCode subagent runner plus an MCP server (and an opencode.json config scaffold) that exposes the taskflow_* tools to OpenCode users.",
  "keywords": [
    "opencode",
    "mcp",
    "taskflow",
    "orchestration",
    "subagents",
    "workflow"
  ],
  "license": "MIT",
  "author": "heggria <bshengtao@gmail.com>",
  "homepage": "https://github.com/heggria/taskflow#readme",
  "bugs": {
    "url": "https://github.com/heggria/taskflow/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/heggria/taskflow.git",
    "directory": "packages/opencode-taskflow"
  },
  "type": "module",
  "engines": {
    "node": ">=22.19.0"
  },
  "main": "./dist/opencode-runner.js",
  "types": "./dist/opencode-runner.d.ts",
  "bin": {
    "opencode-taskflow-mcp": "./dist/mcp/bin.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json && node ../../scripts/copy-readme.mjs opencode-taskflow",
    "prepublishOnly": "npm run build"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "taskflow-core": "0.1.5",
    "taskflow-mcp": "0.1.5"
  }
}
