{
  "name": "taskflow-core",
  "version": "0.2.3",
  "description": "Host-neutral engine for declarative, verifiable task-DAG orchestration — the runtime, DSL, cache, and verification shared by pi-taskflow, codex-taskflow, claude-taskflow, opencode-taskflow, and grok-taskflow.",
  "keywords": [
    "taskflow",
    "dag",
    "orchestration",
    "subagents",
    "workflow"
  ],
  "license": "MIT",
  "author": "heggria <bshengtao@gmail.com>",
  "homepage": "https://github.com/heggria/taskflow#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/heggria/taskflow.git",
    "directory": "packages/taskflow-core"
  },
  "bugs": {
    "url": "https://github.com/heggria/taskflow/issues"
  },
  "type": "module",
  "engines": {
    "node": ">=22.19.0"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "development": "./src/index.ts",
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./resources/*": null,
    "./*": {
      "development": "./src/*.ts",
      "types": "./dist/*.d.ts",
      "default": "./dist/*.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "rm -rf dist && tsc -p tsconfig.build.json && node ../../scripts/copy-agents.mjs && node ../../scripts/copy-readme.mjs taskflow-core && node ../../scripts/stamp-build-info.mjs",
    "prepublishOnly": "npm run build"
  },
  "publishConfig": {
    "access": "public",
    "exports": {
      ".": { "types": "./dist/index.d.ts", "default": "./dist/index.js" },
      "./resources/*": null,
      "./*": { "types": "./dist/*.d.ts", "default": "./dist/*.js" }
    }
  },
  "peerDependencies": {
    "typebox": "*"
  }
}
