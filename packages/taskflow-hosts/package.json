{
  "name": "taskflow-hosts",
  "version": "0.2.2",
  "description": "Shared host-runner collection for taskflow — the codex, claude, opencode, and grok SubagentRunner implementations + their argv builders and event-stream parsers. The per-host MCP servers, plugin scaffolds, and bins live in codex-taskflow / claude-taskflow / opencode-taskflow / grok-taskflow; this package holds just the runners so a new host can be added in one place.",
  "homepage": "https://github.com/heggria/taskflow#readme",
  "author": "heggria <bshengtao@gmail.com>",
  "bugs": {
    "url": "https://github.com/heggria/taskflow/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/heggria/taskflow.git",
    "directory": "packages/taskflow-hosts"
  },
  "type": "module",
  "engines": {
    "node": ">=22.19.0"
  },
  "exports": {
    ".": {
      "development": "./src/index.ts",
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./codex": {
      "development": "./src/codex-runner.ts",
      "types": "./dist/codex-runner.d.ts",
      "default": "./dist/codex-runner.js"
    },
    "./claude": {
      "development": "./src/claude-runner.ts",
      "types": "./dist/claude-runner.d.ts",
      "default": "./dist/claude-runner.js"
    },
    "./opencode": {
      "development": "./src/opencode-runner.ts",
      "types": "./dist/opencode-runner.d.ts",
      "default": "./dist/opencode-runner.js"
    },
    "./grok": {
      "development": "./src/grok-runner.ts",
      "types": "./dist/grok-runner.d.ts",
      "default": "./dist/grok-runner.js"
    },
    "./*": {
      "development": "./src/*.ts",
      "types": "./dist/*.d.ts",
      "default": "./dist/*.js"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "rm -rf dist && tsc -p tsconfig.build.json",
    "prepublishOnly": "npm run build"
  },
  "publishConfig": {
    "access": "public",
    "exports": {
      ".": { "types": "./dist/index.d.ts", "default": "./dist/index.js" },
      "./codex": { "types": "./dist/codex-runner.d.ts", "default": "./dist/codex-runner.js" },
      "./claude": { "types": "./dist/claude-runner.d.ts", "default": "./dist/claude-runner.js" },
      "./opencode": { "types": "./dist/opencode-runner.d.ts", "default": "./dist/opencode-runner.js" },
      "./grok": { "types": "./dist/grok-runner.d.ts", "default": "./dist/grok-runner.js" },
      "./*": { "types": "./dist/*.d.ts", "default": "./dist/*.js" }
    }
  },
  "dependencies": {
    "taskflow-core": "workspace:*"
  },
  "devDependencies": {
    "typescript": "^7.0.2"
  },
  "keywords": [
    "taskflow",
    "subagent",
    "codex",
    "claude",
    "opencode",
    "grok",
    "grok-build",
    "orchestration"
  ],
  "license": "MIT"
}
