{
  "name": "pi-taskflow-monorepo",
  "version": "0.0.28",
  "private": true,
  "description": "Monorepo for taskflow-core, pi-taskflow, and codex-taskflow.",
  "type": "module",
  "workspaces": [
    "packages/taskflow-core",
    "packages/pi-taskflow",
    "packages/codex-taskflow"
  ],
  "scripts": {
    "typecheck": "tsc --noEmit",
    "test": "PI_TASKFLOW_BUILTIN_AGENTS_DIR= node --experimental-strip-types --test 'packages/*/test/*.test.ts'",
    "test:core": "PI_TASKFLOW_BUILTIN_AGENTS_DIR= node --experimental-strip-types --test 'packages/taskflow-core/test/*.test.ts'",
    "test:pi": "PI_TASKFLOW_BUILTIN_AGENTS_DIR= node --experimental-strip-types --test 'packages/pi-taskflow/test/*.test.ts'",
    "test:codex": "PI_TASKFLOW_BUILTIN_AGENTS_DIR= node --experimental-strip-types --test 'packages/codex-taskflow/test/*.test.ts'",
    "test:e2e-codex": "node --experimental-strip-types packages/codex-taskflow/test/e2e-codex.mts",
    "test:e2e-codex-mcp": "node --experimental-strip-types packages/codex-taskflow/test/e2e-codex-mcp.mts"
  },
  "devDependencies": {
    "@earendil-works/pi-agent-core": "^0.78.0",
    "@earendil-works/pi-ai": "^0.78.0",
    "@earendil-works/pi-coding-agent": "^0.78.0",
    "@earendil-works/pi-tui": "^0.78.0",
    "typebox": "^1.1.38",
    "typescript": "^5.6.0"
  }
}
