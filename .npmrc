# Refuse to install under an unsupported Node version instead of just warning.
# The engines field (>=22) is a hard requirement: the code uses fs.globSync and
# Atomics.wait (Node 22+), and every test/e2e script runs .ts via
# --experimental-strip-types (Node 22.6+). Node 20 and older cannot run this.
engine-strict=true

# Pin the public registry so a contributor's local private mirror never leaks
# its internal URLs into package-lock.json (which would break CI / other clones).
registry=https://registry.npmjs.org/
